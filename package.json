{
  "name": "gakumas-tools-monorepo",
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm --filter gakumas-tools dev",
    "build": "pnpm --filter gakumas-tools build",
    "process": "python -m scripts.process_screenshots_iphone",
    "train:classifier": "python -m scripts.train_classifier",
    "train:classifier:fresh": "python -m scripts.train_classifier --fresh",
    "generate": "./scripts/pull_gkdata.sh && pnpm --filter gakumas-data generate && pnpm --filter gakumas-images generate && python -m scripts.generate",
    "regenerate": "rm -rf gk-img/docs/*s && pnpm generate",
    "test:regression": "node --loader ./scripts/extensionless-loader.mjs ./tests/run.mjs",
    "test:regression:update": "node --loader ./scripts/extensionless-loader.mjs ./tests/run.mjs --update",
    "test:draft": "node --loader ./scripts/extensionless-loader.mjs ./tests/draftPickBoxes.mjs",
    "test:draft:update": "node --loader ./scripts/extensionless-loader.mjs ./tests/draftPickBoxes.mjs --update",
    "test:draft:visualize": "node --loader ./scripts/extensionless-loader.mjs ./tests/draftPickBoxes.mjs --visualize",
    "test:memory": "node --loader ./scripts/extensionless-loader.mjs ./tests/memoryBoxes.mjs",
    "test:memory:update": "node --loader ./scripts/extensionless-loader.mjs ./tests/memoryBoxes.mjs --update",
    "test:memory:visualize": "node --loader ./scripts/extensionless-loader.mjs ./tests/memoryBoxes.mjs --visualize",
    "test:rehearsal": "node --loader ./scripts/extensionless-loader.mjs ./tests/rehearsalScores.mjs",
    "test:rehearsal:update": "node --loader ./scripts/extensionless-loader.mjs ./tests/rehearsalScores.mjs --update",
    "test:rehearsal:unit": "node --test tests/rehearsalRecovery.test.mjs",
    "regression:add": "node --loader ./scripts/extensionless-loader.mjs ./tests/add.mjs",
    "regression:bootstrap": "node --loader ./scripts/extensionless-loader.mjs ./tests/generate-suite.mjs",
    "regression:coverage": "node --loader ./scripts/extensionless-loader.mjs ./tests/coverage.mjs",
    "bench": "node --loader ./scripts/extensionless-loader.mjs ./tests/bench.mjs",
    "bench:update": "node --loader ./scripts/extensionless-loader.mjs ./tests/bench.mjs --update",
    "validate:data": "node --loader ./scripts/extensionless-loader.mjs ./scripts/validate-data.mjs",
    "changelog": "node ./scripts/changelog.js",
    "backup-db": "pnpm --filter gakumas-tools backup-db"
  },
  "dependencies": {
    "gakumas-data": "workspace:*",
    "gakumas-engine": "workspace:*"
  },
  "devDependencies": {
    "onnxruntime-node": "1.24",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  },
  "packageManager": "pnpm@11.0.6"
}
