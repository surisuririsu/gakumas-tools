{
  "name": "gakumas-tools-monorepo",
  "version": "0.1.0",
  "scripts": {
    "dev": "yarn workspace gakumas-tools dev",
    "build": "yarn workspace gakumas-tools build",
    "process": "python -m scripts.process_screenshots_iphone",
    "generate": "./scripts/pull_gkdata.sh && yarn workspace gakumas-data generate && yarn workspace gakumas-data-structured generate && yarn workspace gakumas-images generate && python -m scripts.generate",
    "regenerate": "rm -rf gk-img/docs/*s && yarn generate",
    "test:compare": "node --loader ./scripts/test-compare/extensionless-loader.mjs ./scripts/test-compare/compare-engines.mjs",
    "test:customizations": "node --loader ./scripts/test-compare/extensionless-loader.mjs ./scripts/test-compare/test-customizations.mjs",
    "changelog": "node ./scripts/changelog.js",
    "backup-db": "yarn workspace gakumas-tools backup-db"
  },
  "workspaces": [
    "gakumas-tools",
    "packages/*"
  ],
  "packageManager": "yarn@4.13.0"
}
