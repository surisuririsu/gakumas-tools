{
  "metadata": {
    "title": "Gakumas Tools",
    "description": "Gakumas Tools is a collection of useful tools for producers at Hatsuboshi Gakuen. Calculate required final exam scores for produce ranks, view p-item and skill card information, organize memories, plan and simulate contest loadouts and more. Be the best producer and help your idols shine!"
  },
  "tools": {
    "home": {
      "title": "Home",
      "description": "Overview of available tools"
    },
    "produceRankCalculator": {
      "title": "Produce Rank Calculator",
      "description": "Calculate final exam score required to achieve each produce rank"
    },
    "niaCalculator": {
      "title": "N.I.A Calculator",
      "description": "Calculate audition bonus and produce rank for N.I.A"
    },
    "hifCalculator": {
      "title": "H.I.F Calculator",
      "description": "Calculate produce rank for H.I.F"
    },
    "lessonCalculator": {
      "title": "Lesson Calculator",
      "description": "Calculate parameters gained from lessons"
    },
    "dex": {
      "title": "P-Index",
      "description": "Filter and view p-item and skill card information"
    },
    "pIdolCollection": {
      "title": "P-Idol Collection",
      "description": "Track which p-idols you've collected, with progress breakdowns by rarity, plan, and idol"
    },
    "tierList": {
      "title": "Tier Lists",
      "description": "Create tier lists of skill cards, p-items, p-drinks, or p-idols"
    },
    "memoryCalculator": {
      "title": "Memory Calculator",
      "description": "Calculate probability of getting desired skill card combinations in memories"
    },
    "memories": {
      "title": "Memories",
      "description": "Create or import memories, and search by p-items and skill cards"
    },
    "simulator": {
      "title": "Contest Simulator",
      "description": "Create and simulate contest loadouts, and calculate memory cost"
    },
    "rehearsal": {
      "title": "Rehearsal Parser",
      "description": "Parse scores from rehearsal screenshots"
    }
  },
